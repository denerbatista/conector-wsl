{
  "name": "claude-wsl-terminal-connector",
  "version": "0.3.0",
  "description": "MCP connector that exposes a controlled WSL terminal and filesystem to Claude/Cowork, with zero-config auto-detection.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "src/index.js",
  "bin": {
    "claude-wsl-terminal-connector": "./src/index.js"
  },
  "files": [
    "src",
    "server",
    "manifest.json",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "node ./src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\" \"*.json\" \"*.md\"",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\" \"*.json\" \"*.md\"",
    "package": "mcpb pack",
    "prepublishOnly": "npm run lint && npm test"
  },
  "keywords": [
    "anthropic",
    "claude",
    "cowork",
    "filesystem",
    "mcp",
    "wsl"
  ],
  "license": "MIT",
  "author": "Dener Batista",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/denerbatista/conector-wsl.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "vitest": "^2.1.8"
  }
}
